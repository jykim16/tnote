#!/bin/sh
# Fake tmux for testing. Responds to key subcommands used by tnote.
if [ -n "$FAKE_TMUX_LOG" ]; then
  printf '%s\n' "$*" >> "$FAKE_TMUX_LOG"
fi

case "$1" in
  display-message)
    # Return a fake session name (not a popup session)
    echo ""
    ;;
  list-windows)
    echo ""
    ;;
  list-sessions)
    # Return one orphaned popup session (no attached clients, no matching note file)
    echo "tnote-popup-orphan:0"
    ;;
  *)
    ;;
esac
exit 0
